rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - only owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // BMI records nested collection
      match /bmi_records/{recordId} {
        allow read: if request.auth != null
                    && request.auth.uid == userId;
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.userId == userId
                      && request.resource.data.bmi is number
                      && request.resource.data.bmi > 0
                      && request.resource.data.bmi < 100
                      && request.resource.data.weight is number
                      && request.resource.data.height is number;
        allow update: if request.auth != null
                      && request.auth.uid == userId;
        allow delete: if request.auth != null
                      && request.auth.uid == userId;
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
